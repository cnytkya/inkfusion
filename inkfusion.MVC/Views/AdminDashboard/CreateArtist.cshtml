@model inkfusion.MVC.Models.Artist

@{
    ViewData["Title"] = "Yeni Sanatçı";
    Layout = "_AdminLayout";
}

<style>
    .form-container {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 30px;
        max-width: 600px;
    }

    .form-group {
        margin-bottom: 25px;
    }

    label {
        display: block;
        color: #d4af37;
        font-weight: 600;
        margin-bottom: 8px;
    }

    input[type="text"],
    input[type="url"],
    input[type="number"],
    textarea {
        width: 100%;
        padding: 12px 15px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 6px;
        color: #fff;
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

    textarea {
        resize: vertical;
        min-height: 80px;
    }

    input:focus,
    textarea:focus {
        background: rgba(255, 255, 255, 0.12);
        border-color: #d4af37;
        outline: none;
        box-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
    }

    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 30px;
    }

    .btn {
        flex: 1;
        padding: 12px;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

    .btn-submit {
        background: #d4af37;
        color: #1a1a1a;
    }

    .btn-submit:hover {
        background: #f4d03f;
    }

    .btn-cancel {
        background: rgba(255, 255, 255, 0.1);
        color: #b0b0b0;
    }

    .btn-cancel:hover {
        background: rgba(255, 255, 255, 0.15);
    }

    .error-message {
        background: rgba(220, 53, 69, 0.1);
        border: 1px solid rgba(220, 53, 69, 0.3);
        color: #ff6b6b;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
    }

    .field-error {
        color: #ff6b6b;
        font-size: 12px;
        margin-top: 5px;
        display: block;
    }
</style>

<h2><i class="fas fa-plus me-2"></i>@ViewData["Title"]</h2>

<div class="form-container">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="error-message">
            <i class="fas fa-exclamation-circle me-2"></i>
            Lütfen formu kontrol edin ve tekrar deneyin.
            <ul style="margin-top: 10px; margin-bottom: 0;">
                @foreach (var modelState in ViewData.ModelState.Values)
                {
                    @foreach (var error in modelState.Errors)
                    {
                        <li>@error.ErrorMessage</li>
                    }
                }
            </ul>
        </div>
    }

    <form method="post" action="@Url.Action("CreateArtist", "AdminDashboard")">
        <div class="form-group">
            <label for="firstName">Ad *</label>
            <input type="text" id="firstName" name="FirstName" value="@Model?.FirstName" required>
            <span asp-validation-for="FirstName" class="field-error"></span>
        </div>

        <div class="form-group">
            <label for="lastName">Soyadı *</label>
            <input type="text" id="lastName" name="LastName" value="@Model?.LastName" required>
            <span asp-validation-for="LastName" class="field-error"></span>
        </div>

        <div class="form-group">
            <label for="specialization">Uzmanlık</label>
            <input type="text" id="specialization" name="Specialization" value="@Model?.Specialization" placeholder="örn: Geometrik Dövmeler">
            <span asp-validation-for="Specialization" class="field-error"></span>
        </div>

        <div class="form-group">
            <label for="bio">Biyografi</label>
            <textarea id="bio" name="Bio">@Model?.Bio</textarea>
            <span asp-validation-for="Bio" class="field-error"></span>
        </div>

        <div class="form-group">
            <label for="experienceYears">Tecrübe (Yıl) *</label>
            <input type="number" id="experienceYears" name="ExperienceYears" value="@(Model?.ExperienceYears ?? 1)" min="1" max="50" required>
            <span asp-validation-for="ExperienceYears" class="field-error"></span>
        </div>

        <div class="form-group">
            <label for="imageUrl">Profil Fotoğrafı URL</label>
            <input type="url" id="imageUrl" name="ImageUrl" value="@Model?.ImageUrl" placeholder="https://...">
            <span asp-validation-for="ImageUrl" class="field-error"></span>
        </div>

        <div class="form-group">
            <label for="instagramUrl">Instagram URL</label>
            <input type="url" id="instagramUrl" name="InstagramUrl" value="@Model?.InstagramUrl" placeholder="https://instagram.com/...">
            <span asp-validation-for="InstagramUrl" class="field-error"></span>
        </div>

        <div class="form-group">
            <label>
                <input type="hidden" id="isActiveHidden" name="IsActive" value="false">
                <input type="checkbox" id="isActive" name="IsActive" value="true" @(Model?.IsActive == true || Model == null ? "checked" : "") onchange="document.getElementById('isActiveHidden').disabled = this.checked;">
                Aktif
            </label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-submit">
                <i class="fas fa-save me-2"></i>Kaydet
            </button>
            <a href="@Url.Action("Artists", "AdminDashboard")" class="btn btn-cancel">
                <i class="fas fa-times me-2"></i>İptal
            </a>
        </div>
    </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const checkbox = document.getElementById('isActive');
    const hidden = document.getElementById('isActiveHidden');
    if (checkbox && hidden && checkbox.checked) {
        hidden.disabled = true;
    }
});
</script>
