@model inkfusion.MVC.Models.Service

@{
    ViewData["Title"] = "Yeni Hizmet";
    Layout = "_AdminLayout";
}

<style>
    .form-container {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 30px;
        max-width: 600px;
    }

    .form-group {
        margin-bottom: 25px;
    }

    label {
        display: block;
        color: #d4af37;
        font-weight: 600;
        margin-bottom: 8px;
    }

    input[type="text"],
    input[type="number"],
    textarea {
        width: 100%;
        padding: 12px 15px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 6px;
        color: #fff;
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

    textarea {
        resize: vertical;
        min-height: 80px;
    }

    input:focus,
    textarea:focus {
        background: rgba(255, 255, 255, 0.12);
        border-color: #d4af37;
        outline: none;
        box-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
    }

    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 15px;
    }

    .form-row .form-group {
        margin-bottom: 0;
    }

    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 30px;
    }

    .btn {
        flex: 1;
        padding: 12px;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

    .btn-submit {
        background: #d4af37;
        color: #1a1a1a;
    }

    .btn-submit:hover {
        background: #f4d03f;
    }

    .btn-cancel {
        background: rgba(255, 255, 255, 0.1);
        color: #b0b0b0;
    }

    .btn-cancel:hover {
        background: rgba(255, 255, 255, 0.15);
    }

    .error-message {
        background: rgba(220, 53, 69, 0.1);
        border: 1px solid rgba(220, 53, 69, 0.3);
        color: #ff6b6b;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
    }

    .field-error {
        color: #ff6b6b;
        font-size: 12px;
        margin-top: 5px;
        display: block;
    }
</style>

<h2><i class="fas fa-plus me-2"></i>@ViewData["Title"]</h2>

<div class="form-container">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="error-message">
            <i class="fas fa-exclamation-circle me-2"></i>
            Lütfen formu kontrol edin ve tekrar deneyin.
            <ul style="margin-top: 10px; margin-bottom: 0;">
                @foreach (var modelState in ViewData.ModelState.Values)
                {
                    @foreach (var error in modelState.Errors)
                    {
                        <li>@error.ErrorMessage</li>
                    }
                }
            </ul>
        </div>
    }

    <form method="post" action="@Url.Action("CreateService", "AdminDashboard")">
        <div class="form-group">
            <label for="name">Hizmet Adı *</label>
            <input type="text" id="name" name="Name" value="@Model?.Name" required>
            <span asp-validation-for="Name" class="field-error"></span>
        </div>

        <div class="form-group">
            <label for="description">Açıklama</label>
            <textarea id="description" name="Description">@Model?.Description</textarea>
            <span asp-validation-for="Description" class="field-error"></span>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="price">Fiyat (₺) *</label>
                <input type="number" id="price" name="Price" value="@(Model?.Price ?? 0)" step="0.01" min="0" required>
                <span asp-validation-for="Price" class="field-error"></span>
            </div>

            <div class="form-group">
                <label for="durationMinutes">Süre (dakika) *</label>
                <input type="number" id="durationMinutes" name="DurationMinutes" value="@(Model?.DurationMinutes ?? 60)" min="15" required>
                <span asp-validation-for="DurationMinutes" class="field-error"></span>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group">
                <label for="iconClass">İkon Sınıfı</label>
                <input type="text" id="iconClass" name="IconClass" value="@Model?.IconClass" placeholder="fas fa-icon">
                <span asp-validation-for="IconClass" class="field-error"></span>
            </div>

            <div class="form-group">
                <label for="displayOrder">Görüntü Sırası</label>
                <input type="number" id="displayOrder" name="DisplayOrder" value="@(Model?.DisplayOrder ?? 1)" min="1" max="100">
                <span asp-validation-for="DisplayOrder" class="field-error"></span>
            </div>
        </div>

        <div class="form-group">
            <label for="imageUrl">Hizmet Görseli URL</label>
            <input type="url" id="imageUrl" name="ImageUrl" value="@Model?.ImageUrl" placeholder="https://...">
            <span asp-validation-for="ImageUrl" class="field-error"></span>
        </div>

        <div class="form-group">
            <label>
                <input type="hidden" id="isActiveHidden" name="IsActive" value="false">
                <input type="checkbox" id="isActive" name="IsActive" value="true" @(Model?.IsActive == true || Model == null ? "checked" : "") onchange="document.getElementById('isActiveHidden').disabled = this.checked;">
                Aktif
            </label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-submit">
                <i class="fas fa-save me-2"></i>Kaydet
            </button>
            <a href="@Url.Action("Services", "AdminDashboard")" class="btn btn-cancel">
                <i class="fas fa-times me-2"></i>İptal
            </a>
        </div>
    </form>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const checkbox = document.getElementById('isActive');
    const hidden = document.getElementById('isActiveHidden');
    if (checkbox && hidden && checkbox.checked) {
        hidden.disabled = true;
    }
});
</script>
