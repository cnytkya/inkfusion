@model inkfusion.MVC.Models.GalleryItem

@{
    ViewData["Title"] = "Galeri Fotoğrafı Düzenle";
    Layout = "_AdminLayout";
}

<style>
    .form-container {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 30px;
        max-width: 600px;
    }

    .form-group {
        margin-bottom: 25px;
    }

    label {
        display: block;
        color: #d4af37;
        font-weight: 600;
        margin-bottom: 8px;
    }

    input[type="text"],
    input[type="url"],
    input[type="file"],
    textarea,
    select {
        width: 100%;
        padding: 12px 15px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 6px;
        color: #fff;
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

    input[type="file"] {
        padding: 8px;
        cursor: pointer;
    }

    input[type="file"]::file-selector-button {
        background: #d4af37;
        color: #1a1a1a;
        border: none;
        padding: 8px 16px;
        border-radius: 4px;
        cursor: pointer;
        font-weight: 600;
    }

    input[type="file"]::file-selector-button:hover {
        background: #f4d03f;
    }

    .image-preview {
        margin-top: 15px;
        max-width: 200px;
    }

    .image-preview img {
        width: 100%;
        border-radius: 6px;
        border: 1px solid #d4af37;
    }

    textarea {
        resize: vertical;
        min-height: 100px;
    }

    input:focus,
    textarea:focus,
    select:focus {
        background: rgba(255, 255, 255, 0.12);
        border-color: #d4af37;
        outline: none;
        box-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
    }

    .form-actions {
        display: flex;
        gap: 15px;
        margin-top: 30px;
    }

    .btn {
        flex: 1;
        padding: 12px;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        text-decoration: none;
        display: inline-block;
        text-align: center;
    }

    .btn-submit {
        background: #d4af37;
        color: #1a1a1a;
    }

    .btn-submit:hover {
        background: #f4d03f;
    }

    .btn-cancel {
        background: rgba(255, 255, 255, 0.1);
        color: #b0b0b0;
    }

    .btn-cancel:hover {
        background: rgba(255, 255, 255, 0.15);
    }

    .error-message {
        background: rgba(220, 53, 69, 0.1);
        border: 1px solid rgba(220, 53, 69, 0.3);
        color: #ff6b6b;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
    }

    .field-error {
        color: #ff6b6b;
        font-size: 12px;
        margin-top: 5px;
        display: block;
    }
</style>

<h2><i class="fas fa-plus me-2"></i>@ViewData["Title"]</h2>

<div class="form-container">
    @if (!ViewData.ModelState.IsValid)
    {
        <div class="error-message">
            <i class="fas fa-exclamation-circle me-2"></i>
            Lütfen formu kontrol edin ve tekrar deneyin.
            <ul style="margin-top: 10px; margin-bottom: 0;">
                @foreach (var modelState in ViewData.ModelState.Values)
                {
                    @foreach (var error in modelState.Errors)
                    {
                        <li>@error.ErrorMessage</li>
                    }
                }
            </ul>
        </div>
    }

    <form method="post" action="@Url.Action("EditGallery", "AdminDashboard", new { id = Model.Id })" enctype="multipart/form-data">
        <input type="hidden" name="ImageUrl" value="@Model?.ImageUrl">
        <div class="form-group">
            <label for="title">Fotoğraf Başlığı *</label>
            <input type="text" id="title" name="Title" value="@Model?.Title" required>
            <span asp-validation-for="Title" class="field-error"></span>
        </div>

        <div class="form-group">
            <label for="description">Açıklama</label>
            <textarea id="description" name="Description">@Model?.Description</textarea>
            <span asp-validation-for="Description" class="field-error"></span>
        </div>

        <div class="form-group">
            <label for="imageFile">Fotoğraf Yükle (Değiştirmek İsteğe Bağlı)</label>
            <input type="file" id="imageFile" name="imageFile" accept="image/*" onchange="previewImage(this)">
            <div class="image-preview">
                @if (!string.IsNullOrEmpty(Model?.ImageUrl))
                {
                    <img id="preview" src="@Model.ImageUrl">
                }
                else
                {
                    <img id="preview" style="display:none;">
                }
            </div>
        </div>

        <div class="form-group">
            <label for="categoryId">Kategori</label>
            <select id="categoryId" name="CategoryId">
                <option value="">-- Kategori Seç --</option>
                @if (ViewBag.Categories != null)
                {
                    @foreach (var cat in ViewBag.Categories)
                    {
                        var isSelected = Model?.CategoryId == cat.Id;
                        if (isSelected)
                        {
                            <option value="@cat.Id" selected>@cat.Name</option>
                        }
                        else
                        {
                            <option value="@cat.Id">@cat.Name</option>
                        }
                    }
                }
            </select>
            <span asp-validation-for="CategoryId" class="field-error"></span>
        </div>

        <div class="form-group">
            <label for="artistId">Sanatçı</label>
            <select id="artistId" name="ArtistId">
                <option value="">-- Seçmek İsteğe Bağlı --</option>
                @if (ViewBag.Artists != null)
                {
                    @foreach (var artist in ViewBag.Artists)
                    {
                        if (Model?.ArtistId == artist.Id)
                        {
                            <option value="@artist.Id" selected>@artist.FirstName @artist.LastName</option>
                        }
                        else
                        {
                            <option value="@artist.Id">@artist.FirstName @artist.LastName</option>
                        }
                    }
                }
            </select>
        </div>

        <div class="form-group">
            <label for="displayOrder">Görüntü Sırası</label>
            <input type="number" id="displayOrder" name="DisplayOrder" value="@(Model?.DisplayOrder ?? 1)" min="1" max="100">
        </div>

        <div class="form-group">
            <label for="isActive">
                <input type="hidden" id="isActiveHidden" name="IsActive" value="false">
                <input type="checkbox" id="isActive" name="IsActive" value="true" @(Model?.IsActive == true ? "checked" : "") onchange="document.getElementById('isActiveHidden').disabled = this.checked;">
                Aktif
            </label>
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-submit">
                <i class="fas fa-save me-2"></i>Güncelle
            </button>
            <a href="@Url.Action("Galleries", "AdminDashboard")" class="btn btn-cancel">
                <i class="fas fa-times me-2"></i>İptal
            </a>
        </div>
    </form>
</div>

<script>
function previewImage(input) {
    const preview = document.getElementById('preview');
    if (input.files && input.files[0]) {
        const reader = new FileReader();
        reader.onload = function(e) {
            preview.src = e.target.result;
            preview.style.display = 'block';
        };
        reader.readAsDataURL(input.files[0]);
    }
}

document.addEventListener('DOMContentLoaded', function() {
    const checkbox = document.getElementById('isActive');
    const hidden = document.getElementById('isActiveHidden');
    if (checkbox && hidden && checkbox.checked) {
        hidden.disabled = true;
    }
});
</script>
