@model IEnumerable<inkfusion.MVC.Models.Comment>

@{
    ViewData["Title"] = "Yorumlar";
    Layout = "_AdminLayout";
}

<style>
    .page-header {
        margin-bottom: 30px;
    }

    .comment-card {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 20px;
        margin-bottom: 20px;
    }

    .comment-header {
        display: flex;
        justify-content: space-between;
        align-items: start;
        margin-bottom: 15px;
    }

    .comment-user {
        font-weight: 600;
        color: #d4af37;
    }

    .comment-date {
        color: #b0b0b0;
        font-size: 13px;
    }

    .comment-rating {
        color: #ffc107;
        margin-bottom: 10px;
    }

    .comment-text {
        color: #f8f9fa;
        line-height: 1.6;
        margin-bottom: 15px;
    }

    .comment-status {
        display: inline-block;
        padding: 5px 10px;
        border-radius: 4px;
        font-size: 12px;
        font-weight: 600;
        margin-bottom: 15px;
    }

    .badge-pending {
        background: rgba(255, 193, 7, 0.3);
        color: #ffc107;
    }

    .badge-approved {
        background: rgba(40, 167, 69, 0.3);
        color: #28a745;
    }

    .comment-actions {
        display: flex;
        gap: 10px;
    }

    .action-btn {
        padding: 8px 15px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 13px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-approve {
        background: #28a745;
        color: white;
    }

    .btn-approve:hover {
        background: #218838;
    }

    .btn-delete {
        background: #dc3545;
        color: white;
    }

    .btn-delete:hover {
        background: #c82333;
    }

    .empty-state {
        background: rgba(255, 255, 255, 0.05);
        padding: 60px 20px;
        border-radius: 10px;
        text-align: center;
        color: #b0b0b0;
    }
</style>

<div class="page-header">
    <h2><i class="fas fa-comments me-2"></i>Yorumlar</h2>
</div>

@if (Model != null && Model.Any())
{
    @foreach (var comment in Model.OrderByDescending(c => c.CreatedAt))
    {
        <div class="comment-card">
            <div class="comment-header">
                <div>
                    <span class="comment-user">@comment.User?.FirstName @comment.User?.LastName</span>
                    <div class="comment-date">@comment.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
                </div>
                <span class="comment-status badge-@(comment.IsApproved ? "approved" : "pending")">
                    @(comment.IsApproved ? "Onaylı" : "Beklemede")
                </span>
            </div>

            <div class="comment-rating">
                @for (int i = 0; i < comment.Rating; i++)
                {
                    <i class="fas fa-star"></i>
                }
            </div>

            <div class="comment-text">@comment.Text</div>

            <div class="comment-actions">
                @if (!comment.IsApproved)
                {
                    <form method="post" action="@Url.Action("ApproveComment", "AdminDashboard", new { id = comment.Id })" style="display: inline;">
                        <button type="submit" class="action-btn btn-approve">Onayla</button>
                    </form>
                }
                <form method="post" action="@Url.Action("DeleteComment", "AdminDashboard", new { id = comment.Id })" style="display: inline;">
                    <button type="submit" class="action-btn btn-delete" onclick="return confirm('Emin misiniz?')">Sil</button>
                </form>
            </div>
        </div>
    }
}
else
{
    <div class="empty-state">
        <i class="fas fa-comment-slash" style="font-size: 64px; color: #d4af37;"></i>
        <p>Henüz yorum yok.</p>
    </div>
}
