@model IEnumerable<inkfusion.MVC.Models.GalleryItem>

@{
    ViewData["Title"] = "Galeri Yönetimi";
    Layout = "_AdminLayout";
}

<style>
    .page-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 30px;
    }

    .btn-primary {
        background: #d4af37;
        color: #1a1a1a;
        border: none;
        padding: 10px 20px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-primary:hover {
        background: #f4d03f;
    }

    .btn-secondary {
        background: #6c757d;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 6px;
        cursor: pointer;
        font-weight: 600;
        transition: all 0.3s ease;
        margin-left: 10px;
    }

    .btn-secondary:hover {
        background: #5a6268;
    }

    .button-group {
        display: flex;
        gap: 10px;
    }

    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .gallery-card {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        overflow: hidden;
        transition: all 0.3s ease;
    }

    .gallery-card:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: #d4af37;
        transform: translateY(-5px);
    }

    .gallery-image {
        width: 100%;
        height: 200px;
        background: rgba(212, 175, 55, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 48px;
        color: #d4af37;
    }

    .gallery-info {
        padding: 15px;
    }

    .gallery-info h4 {
        color: #d4af37;
        margin-bottom: 10px;
        font-size: 16px;
    }

    .gallery-info p {
        color: #b0b0b0;
        font-size: 13px;
        margin-bottom: 10px;
    }

    .gallery-actions {
        display: flex;
        gap: 10px;
        margin-top: 10px;
    }

    .btn-edit, .btn-delete {
        flex: 1;
        padding: 8px;
        border: none;
        border-radius: 4px;
        cursor: pointer;
        font-size: 12px;
        font-weight: 600;
        transition: all 0.3s ease;
    }

    .btn-edit {
        background: #007bff;
        color: white;
    }

    .btn-edit:hover {
        background: #0056b3;
    }

    .btn-delete {
        background: #dc3545;
        color: white;
    }

    .btn-delete:hover {
        background: #c82333;
    }

    .empty-state {
        background: rgba(255, 255, 255, 0.05);
        padding: 60px 20px;
        border-radius: 10px;
        text-align: center;
        color: #b0b0b0;
    }

    .empty-state i {
        font-size: 64px;
        color: #d4af37;
        margin-bottom: 20px;
        display: block;
    }
</style>

@if (TempData["Success"] != null)
{
    <div style="background: rgba(40, 167, 69, 0.15); border: 1px solid rgba(40, 167, 69, 0.4); color: #28a745; padding: 15px; border-radius: 6px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
        <i class="fas fa-check-circle"></i>
        <span>@TempData["Success"]</span>
    </div>
}

<div class="page-header">
    <h2><i class="fas fa-images me-2"></i>Galeri Yönetimi</h2>
    <div class="button-group">
        <form method="post" action="@Url.Action("ImportImages", "AdminDashboard")" style="display: inline;">
            <button type="submit" class="btn-secondary" onclick="return confirm('wwwroot/img klasöründeki 122 resimi DB\'ye yazacak. Devam etmek istiyor musun?')">
                <i class="fas fa-download me-2"></i>Resimleri İçeri Aktar
            </button>
        </form>
        <a href="@Url.Action("CreateGallery", "AdminDashboard")" class="btn-primary">
            <i class="fas fa-plus me-2"></i>Yeni Fotoğraf
        </a>
    </div>
</div>

@if (Model != null && Model.Any())
{
    <div class="gallery-grid">
        @foreach (var item in Model)
        {
            <div class="gallery-card">
                <div class="gallery-image">
                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                    {
                        <img src="@item.ImageUrl" alt="@item.Title" style="width: 100%; height: 100%; object-fit: cover;">
                    }
                    else
                    {
                        <i class="fas fa-image"></i>
                    }
                </div>
                <div class="gallery-info">
                    <h4>@item.Title</h4>
                    <p>@(item.Description?.Length > 50 ? item.Description.Substring(0, 50) + "..." : item.Description)</p>
                    <p>
                        <small style="color: #b0b0b0;">
                            📁 Kategori: <strong>@item.Category</strong>
                        </small>
                    </p>
                    @if (item.Artist != null)
                    {
                        <p>
                            <small style="color: #d4af37;">
                                👨‍🎨 Sanatçı: <strong>@item.Artist.FirstName @item.Artist.LastName</strong>
                            </small>
                        </p>
                    }
                    <p>
                        <small style="color: #b0b0b0;">
                            📅 @item.CreatedAt.ToString("dd.MM.yyyy")
                        </small>
                    </p>
                    <div class="gallery-actions">
                        <a href="@Url.Action("EditGallery", "AdminDashboard", new { id = item.Id })" class="btn-edit">
                            <i class="fas fa-edit"></i> Düzenle
                        </a>
                        <form method="post" action="@Url.Action("DeleteGallery", "AdminDashboard", new { id = item.Id })" style="flex: 1;">
                            <button type="submit" class="btn-delete" onclick="return confirm('Emin misiniz?')" style="width: 100%;">
                                <i class="fas fa-trash"></i> Sil
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="empty-state">
        <i class="fas fa-image-slash"></i>
        <p>Henüz galeri fotoğrafı yok. Yeni fotoğraf ekleyin!</p>
    </div>
}
