@model inkfusion.MVC.Models.User

@{
    ViewData["Title"] = "Profil";
    Layout = "_AdminLayout";
}

<style>
    .profile-container {
        background: rgba(255, 255, 255, 0.05);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 30px;
        max-width: 600px;
    }

    .profile-header {
        display: flex;
        align-items: center;
        margin-bottom: 30px;
        padding-bottom: 30px;
        border-bottom: 2px solid rgba(255, 255, 255, 0.1);
    }

    .profile-avatar {
        width: 120px;
        height: 120px;
        border-radius: 50%;
        background: linear-gradient(135deg, #d4af37 0%, #f4d03f 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1a1a1a;
        font-size: 48px;
        font-weight: 700;
        margin-right: 25px;
        flex-shrink: 0;
    }

    .profile-info h2 {
        color: #d4af37;
        margin: 0 0 5px 0;
        font-size: 24px;
    }

    .profile-info p {
        color: #b0b0b0;
        margin: 5px 0;
        font-size: 14px;
    }

    .profile-info .user-role {
        display: inline-block;
        background: rgba(212, 175, 55, 0.2);
        color: #d4af37;
        padding: 5px 12px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 600;
        margin-top: 10px;
    }

    .profile-section {
        margin-bottom: 30px;
    }

    .profile-section h3 {
        color: #d4af37;
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 15px;
        border-bottom: 2px solid rgba(212, 175, 55, 0.3);
        padding-bottom: 10px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        padding: 12px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .info-row:last-child {
        border-bottom: none;
    }

    .info-label {
        color: #b0b0b0;
        font-weight: 600;
        font-size: 14px;
    }

    .info-value {
        color: #f8f9fa;
        text-align: right;
    }

    .profile-actions {
        display: flex;
        gap: 15px;
        margin-top: 30px;
    }

    .btn {
        flex: 1;
        padding: 12px;
        border: none;
        border-radius: 6px;
        font-weight: 600;
        cursor: pointer;
        text-decoration: none;
        display: inline-block;
        text-align: center;
        transition: all 0.3s ease;
    }

    .btn-primary {
        background: #d4af37;
        color: #1a1a1a;
    }

    .btn-primary:hover {
        background: #f4d03f;
    }

    .btn-secondary {
        background: rgba(255, 255, 255, 0.1);
        color: #b0b0b0;
    }

    .btn-secondary:hover {
        background: rgba(255, 255, 255, 0.15);
    }

    .empty-state {
        text-align: center;
        color: #b0b0b0;
        padding: 40px;
    }
</style>

@if (TempData["Success"] != null)
{
    <div style="background: rgba(40, 167, 69, 0.15); border: 1px solid rgba(40, 167, 69, 0.4); color: #28a745; padding: 15px; border-radius: 6px; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;">
        <i class="fas fa-check-circle"></i>
        <span>@TempData["Success"]</span>
    </div>
}

<h2><i class="fas fa-user-circle me-2"></i>Admin Profili</h2>

<div class="profile-container">
    @if (Model != null)
    {
        <div class="profile-header">
            <div class="profile-avatar">
                @if (!string.IsNullOrEmpty(Model.ProfileImageUrl))
                {
                    <img src="@Model.ProfileImageUrl" alt="Profil" style="width: 100%; height: 100%; border-radius: 50%; object-fit: cover;">
                }
                else
                {
                    @($"{Model.FirstName?.FirstOrDefault()}{Model.LastName?.FirstOrDefault()}".ToUpper())
                }
            </div>
            <div class="profile-info">
                <h2>@Model.FirstName @Model.LastName</h2>
                <p><i class="fas fa-envelope me-2"></i>@Model.Email</p>
                <p><i class="fas fa-user me-2"></i>@Model.Username</p>
                <span class="user-role"><i class="fas fa-crown me-2"></i>Admin</span>
            </div>
        </div>

        <div class="profile-section">
            <h3><i class="fas fa-info-circle me-2"></i>Kişisel Bilgiler</h3>
            <div class="info-row">
                <span class="info-label">Ad</span>
                <span class="info-value">@Model.FirstName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Soyadı</span>
                <span class="info-value">@Model.LastName</span>
            </div>
            <div class="info-row">
                <span class="info-label">Telefon</span>
                <span class="info-value">@(Model.PhoneNumber ?? "Belirtilmemiş")</span>
            </div>
            <div class="info-row">
                <span class="info-label">E-posta</span>
                <span class="info-value">@Model.Email</span>
            </div>
        </div>

        <div class="profile-section">
            <h3><i class="fas fa-history me-2"></i>Hesap Bilgileri</h3>
            <div class="info-row">
                <span class="info-label">Kayıt Tarihi</span>
                <span class="info-value">@Model.CreatedAt.ToString("dd.MM.yyyy")</span>
            </div>
            @if (Model.LastLoginAt.HasValue)
            {
                <div class="info-row">
                    <span class="info-label">Son Giriş</span>
                    <span class="info-value">@Model.LastLoginAt?.ToString("dd.MM.yyyy HH:mm")</span>
                </div>
            }
            <div class="info-row">
                <span class="info-label">Durum</span>
                <span class="info-value">
                    <span style="color: @(Model.IsActive ? "#28a745" : "#dc3545");">
                        @(Model.IsActive ? "Aktif" : "İnaktif")
                    </span>
                </span>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.Bio))
        {
            <div class="profile-section">
                <h3><i class="fas fa-align-left me-2"></i>Biyografi</h3>
                <p style="color: #f8f9fa; margin: 0;">@Model.Bio</p>
            </div>
        }

        <div class="profile-actions">
            <a href="@Url.Action("EditProfile", "AdminDashboard")" class="btn btn-primary">
                <i class="fas fa-edit me-2"></i>Düzenle
            </a>
            <a href="@Url.Action("Index", "AdminDashboard")" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-2"></i>Geri
            </a>
        </div>
    }
    else
    {
        <div class="empty-state">
            <i class="fas fa-user-slash" style="font-size: 48px; color: #d4af37;"></i>
            <p style="margin-top: 20px;">Profil bulunamadı.</p>
        </div>
    }
</div>
