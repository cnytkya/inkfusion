@{
    ViewData["Title"] = "Dashboard - ";
}

<style>
    .dashboard-container {
        padding-top: 80px;
        padding-bottom: 40px;
        min-height: 100vh;
    }

    .dashboard-header {
        background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
        padding: 30px;
        border-radius: 10px;
        margin-bottom: 30px;
        color: #fff;
        border-left: 4px solid #d4af37;
    }

    .dashboard-header h1 {
        color: #d4af37;
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        margin-bottom: 10px;
    }

    .dashboard-header p {
        color: #b0b0b0;
        margin: 0;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
        gap: 20px;
        margin-bottom: 30px;
    }

    .dashboard-card {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 10px;
        padding: 25px;
        text-align: center;
        transition: all 0.3s ease;
    }

    .dashboard-card:hover {
        background: rgba(255, 255, 255, 0.08);
        border-color: #d4af37;
        transform: translateY(-5px);
    }

    .dashboard-card i {
        font-size: 40px;
        color: #d4af37;
        margin-bottom: 15px;
        display: block;
    }

    .dashboard-card h3 {
        color: #fff;
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        margin-bottom: 10px;
        font-size: 18px;
    }

    .dashboard-card p {
        color: #b0b0b0;
        font-size: 14px;
        margin: 0;
    }

    .logout-btn {
        background: linear-gradient(135deg, #dc3545 0%, #c82333 100%);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 6px;
        font-family: 'Poppins', sans-serif;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .logout-btn:hover {
        background: linear-gradient(135deg, #c82333 0%, #dc3545 100%);
        transform: translateY(-2px);
    }
</style>

<div class="dashboard-container">
    <div class="container">
        <div class="dashboard-header">
            <h1><i class="fas fa-tachometer-alt me-2"></i>Hoş Geldiniz Admin Panelinde</h1>
            <p>Sistem istatistiklerini ve yönetim seçeneklerini görmek için aşağıdaki kartları kullanın.</p>
            <button class="logout-btn mt-3" onclick="window.location.href='@Url.Action("Index", "Home")'">
                <i class="fas fa-sign-out-alt me-2"></i>Çıkış Yap
            </button>
        </div>

        <div class="dashboard-grid">
            <div class="dashboard-card">
                <i class="fas fa-image"></i>
                <h3>Galeri Yönetimi</h3>
                <p>Resim ve videoları yönetin</p>
            </div>

            <div class="dashboard-card">
                <i class="fas fa-user-tie"></i>
                <h3>Sanatçılar</h3>
                <p>Sanatçı bilgilerini düzenleyin</p>
            </div>

            <div class="dashboard-card">
                <i class="fas fa-calendar-alt"></i>
                <h3>Randevular</h3>
                <p>Müşteri randevularını yönetin</p>
            </div>

            <div class="dashboard-card">
                <i class="fas fa-star"></i>
                <h3>Yorumlar</h3>
                <p>Müşteri yorumlarını görüntüleyin</p>
            </div>

            <div class="dashboard-card">
                <i class="fas fa-cog"></i>
                <h3>Ayarlar</h3>
                <p>Site ayarlarını yapılandırın</p>
            </div>

            <div class="dashboard-card">
                <i class="fas fa-bar-chart"></i>
                <h3>İstatistikler</h3>
                <p>Detaylı raporları görüntüleyin</p>
            </div>
        </div>
    </div>
</div>
