<!-- Contact Section -->
<section id="contact" class="section-padding bg-dark-custom">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <div class="section-heading">
                    <h2 class="section-title" data-lang-key="contact-title">İletişim</h2>
                    <div class="section-divider"></div>
                    <p class="section-subtitle" data-lang-key="contact-subtitle">Randevu ve bilgi almak için bize ulaşın</p>
                </div>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-lg-8 mx-auto">
                <form id="contactForm">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <input type="text" class="form-control" placeholder="Adınız Soyadınız" required data-lang-key="contact-name-placeholder">
                        </div>
                        <div class="col-md-6 mb-3">
                            <input type="email" class="form-control" placeholder="E-posta Adresiniz" required data-lang-key="contact-email-placeholder">
                        </div>
                    </div>
                    <div class="mb-3">
                        <input type="text" class="form-control" placeholder="Konu" data-lang-key="contact-subject-placeholder">
                    </div>
                    <div class="mb-3">
                        <textarea class="form-control" rows="5" placeholder="Mesajınız" required data-lang-key="contact-message-placeholder"></textarea>
                    </div>
                    <div class="text-center">
                        <button type="submit" class="btn btn-primary" data-lang-key="contact-submit-btn">Gönder</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>

