@* @{
    ViewData["Title"] = "InkFusion - Piercing Tattoo Studio";
} *@

<!-- Hero Section -->
<section id="home" class="hero-section">
    <div class="video-background">
        <video autoplay muted loop playsinline id="hero-video">
            <source src="videos/v1.MP4" type="video/mp4">
            <!-- Farklı tarayıcılar için başka formatlar ekleyebiliriz -->
        </video>
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <div class="container">
            <div class="row">
                <div class="col-lg-8 mx-auto text-center">
                    <h1 class="hero-title" data-lang-key="hero-title">Sanatını <span class="text-accent">Vücudunda</span> Taşı</h1>
                    <p class="hero-subtitle" data-lang-key="hero-subtitle">Profesyonel dövme sanatçıları ile hayalindeki dövmeyi gerçeğe dönüştürüyoruz.</p>
                    <div class="hero-buttons mt-4">
                        <a href="#contact" class="btn btn-primary me-3" data-lang-key="book-now">Randevu Al</a>
                        <a href="#gallery" class="btn btn-outline" data-lang-key="view-work">İşlerimize Bak</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="hero-scroll">
        <a href="#about"><i class="fas fa-chevron-down"></i></a>
    </div>
</section>

<!-- About Section -->
<section id="about" class="section-padding">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="about-image">
                    <div class="image-frame"></div>
                    <div class="image-main"></div>
                </div>
            </div>
            <div class="col-lg-6">
                <div class="section-heading">
                    <h2 class="section-title" data-lang-key="about-title">Hakkımızda</h2>
                    <div class="section-divider"></div>
                </div>
                <p class="about-text" data-lang-key="about-text">
                    10 yılı aşkın tecrübemizle, İstanbul'un en gözde dövme stüdyosu olarak
                    hizmet vermekteyiz. Uzman ekibimiz ve steril çalışma ortamımızla
                    müşterilerimize en kaliteli hizmeti sunmaktan gurur duyuyoruz.
                </p>
                <div class="about-features">
                    <div class="feature-item">
                        <i class="fas fa-star feature-icon"></i>
                        <div>
                            <h4 data-lang-key="feature1-title">Özel Tasarımlar</h4>
                            <p data-lang-key="feature1-text">Tamamen size özel ve benzersiz çizimler.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-award feature-icon"></i>
                        <div>
                            <h4 data-lang-key="feature2-title">Kaliteli İşçilik</h4>
                            <p data-lang-key="feature2-text">En kaliteli mürekkep ve ekipmanlarla çalışıyoruz.</p>
                        </div>
                    </div>
                    <div class="feature-item">
                        <i class="fas fa-users feature-icon"></i>
                        <div>
                            <h4 data-lang-key="feature3-title">Uzman Ekip</h4>
                            <p data-lang-key="feature3-text">Alanında uzman deneyimli dövme sanatçıları.</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- Services Section -->
<section id="services" class="section-padding bg-dark-custom">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto text-center">
                <div class="section-heading">
                    <h2 class="section-title" data-lang-key="services-title">Hizmetlerimiz</h2>
                    <div class="section-divider"></div>
                    <p class="section-subtitle" data-lang-key="services-subtitle">Size özel çözümler sunuyoruz</p>
                </div>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-md-4 mb-4">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-drafting-compass"></i>
                    </div>
                    <h3 data-lang-key="service1-title">Özel Tasarım</h3>
                    <p data-lang-key="service1-text">Hayalinizdeki dövmeyi birlikte tasarlayalım. Tamamen size özel ve özgün çizimler.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-paint-brush"></i>
                    </div>
                    <h3 data-lang-key="service2-title">Renkli Dövmeler</h3>
                    <p data-lang-key="service2-text">Canlı ve kalıcı renklerle hayalinizdeki dövmeyi sanat eserine dönüştürüyoruz.</p>
                </div>
            </div>
            <div class="col-md-4 mb-4">
                <div class="service-card">
                    <div class="service-icon">
                        <i class="fas fa-eraser"></i>
                    </div>
                    <h3 data-lang-key="service3-title">Dövme Silme</h3>
                    <p data-lang-key="service3-text">Lazer teknolojisi ile istemediğiniz dövmelerden kurtulun.</p>
                </div>
            </div>
        </div>
    </div>
</section>

