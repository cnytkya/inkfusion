@model LoginModel

@{
    ViewData["Title"] = "Giriş Yap - ";
}

<style>
    .login-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        padding-top: 60px;
        background: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
    }

    .login-box {
        background: rgba(255, 255, 255, 0.05);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 12px;
        padding: 40px;
        width: 100%;
        max-width: 400px;
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .login-box h2 {
        text-align: center;
        color: #fff;
        margin-bottom: 30px;
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        font-size: 28px;
    }

    .login-box .form-group {
        margin-bottom: 20px;
    }

    .login-box label {
        display: block;
        color: #b0b0b0;
        font-size: 14px;
        margin-bottom: 8px;
        font-family: 'Poppins', sans-serif;
        font-weight: 500;
    }

    .login-box input[type="email"],
    .login-box input[type="password"] {
        width: 100%;
        padding: 12px 15px;
        background: rgba(255, 255, 255, 0.08);
        border: 1px solid rgba(255, 255, 255, 0.15);
        border-radius: 6px;
        color: #fff;
        font-family: 'Poppins', sans-serif;
        font-size: 14px;
        transition: all 0.3s ease;
        box-sizing: border-box;
    }

    .login-box input[type="email"]:focus,
    .login-box input[type="password"]:focus {
        background: rgba(255, 255, 255, 0.12);
        border-color: #d4af37;
        outline: none;
        box-shadow: 0 0 10px rgba(212, 175, 55, 0.3);
    }

    .login-box input[type="email"]::placeholder,
    .login-box input[type="password"]::placeholder {
        color: #808080;
    }

    .remember-me {
        display: flex;
        align-items: center;
        margin-bottom: 25px;
    }

    .remember-me input[type="checkbox"] {
        margin-right: 8px;
        cursor: pointer;
        width: 18px;
        height: 18px;
    }

    .remember-me label {
        margin: 0;
        color: #b0b0b0;
        font-size: 13px;
        cursor: pointer;
    }

    .login-btn {
        width: 100%;
        padding: 12px;
        background: linear-gradient(135deg, #d4af37 0%, #f4d03f 100%);
        border: none;
        border-radius: 6px;
        color: #1a1a1a;
        font-family: 'Poppins', sans-serif;
        font-weight: 600;
        font-size: 16px;
        cursor: pointer;
        transition: all 0.3s ease;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .login-btn:hover {
        background: linear-gradient(135deg, #f4d03f 0%, #d4af37 100%);
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(212, 175, 55, 0.4);
    }

    .login-btn:active {
        transform: translateY(0);
    }

    .error-message {
        background: rgba(220, 53, 69, 0.1);
        border: 1px solid rgba(220, 53, 69, 0.3);
        color: #ff6b6b;
        padding: 12px;
        border-radius: 6px;
        margin-bottom: 20px;
        font-size: 13px;
        font-family: 'Poppins', sans-serif;
    }

    .field-error {
        color: #ff6b6b;
        font-size: 12px;
        margin-top: 5px;
        display: block;
        font-family: 'Poppins', sans-serif;
    }

    .login-footer {
        text-align: center;
        margin-top: 20px;
        font-size: 13px;
        color: #b0b0b0;
    }

    .login-footer a {
        color: #d4af37;
        text-decoration: none;
        transition: color 0.3s ease;
    }

    .login-footer a:hover {
        color: #f4d03f;
    }

    .demo-credentials {
        background: rgba(212, 175, 55, 0.1);
        border-left: 3px solid #d4af37;
        padding: 12px;
        margin-top: 20px;
        border-radius: 4px;
        font-size: 12px;
        color: #d4af37;
        font-family: 'Poppins', sans-serif;
    }

    .demo-credentials strong {
        display: block;
        margin-bottom: 5px;
    }
</style>

<div class="login-container">
    <div class="login-box">
        <h2><i class="fas fa-lock me-2"></i>Giriş Yap</h2>

        <form method="post" action="@Url.Action("Index", "Login")">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="error-message">
                    <i class="fas fa-exclamation-circle me-2"></i>
                    Giriş başarısız. E-posta ve şifrenizi kontrol edin.
                </div>
            }

            <div class="form-group">
                <label for="email">E-posta Adresi</label>
                <input type="email"
                       id="email"
                       name="Email"
                       class="form-control"
                       placeholder="E-posta adresinizi girin"
                       value="@Model?.Email"
                       required>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <div class="form-group">
                <label for="password">Şifre</label>
                <input type="password"
                       id="password"
                       name="Password"
                       class="form-control"
                       placeholder="Şifrenizi girin"
                       required>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <div class="remember-me">
                <input type="checkbox" id="rememberMe" name="RememberMe" value="true">
                <label for="rememberMe">Beni hatırla</label>
            </div>

            <button type="submit" class="login-btn">
                <i class="fas fa-sign-in-alt me-2"></i>Giriş Yap
            </button>

            <div class="demo-credentials">
                <strong>Demo Hesabı:</strong>
                Email: admin@inkfusion.com<br>
                Şifre: admin123
            </div>
        </form>

        <div class="login-footer">
            <p>Hesabınız yok mu? <a href="#">Kayıt Ol</a></p>
        </div>
    </div>
</div>
